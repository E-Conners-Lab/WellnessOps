# WellnessOps — Environment Variables
# Copy to .env and fill in values. Never commit .env (SEC-12).

# Database
DATABASE_URL=postgresql+asyncpg://wellnessops:localdev@localhost:5432/wellnessops

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8100

# LLM Backend: "ollama" (local) or "claude" (API)
LLM_BACKEND=ollama

# Ollama (local LLM -- default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FAST_MODEL=llama3.1:8b
OLLAMA_REASONING_MODEL=llama3.1:8b

# Claude API (SEC-12: load from Vault in production)
# Only needed if LLM_BACKEND=claude
ANTHROPIC_API_KEY=your-key-here

# PII Encryption (AES-256-GCM) -- generate with:
# python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
PII_ENCRYPTION_KEY=your-base64-key-here

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
ENVIRONMENT=development
DEBUG=true

# File uploads
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=25
